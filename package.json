    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "prettier": "^3.5.3",
    "vite": "^6.0.7",
    "vite-plugin-checker": "^0.8.0"
  }
