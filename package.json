    "@mui/lab": "^7.0.0-beta.10",
    "@mui/material": "^7.0.1",
    "@react-pdf/renderer": "^4.3.0",
    "@tanstack/react-query": "^5.71.5",
    "@tinymce/tinymce-react": "^6.1.0",
    "antd": "^5.24.6",
    "antd-img-crop": "^4.24.0",
    "apexcharts": "^4.5.0",
    "axios": "^1.8.4",
